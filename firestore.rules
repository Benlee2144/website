rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
// THE PRAYER REALM — Firestore security rules (v2)
//
// These rules are what actually protect the realm. They run on
// Google's servers, so even someone who edits the website code in
// their browser cannot break them.
//
// HOW TO INSTALL / UPDATE:
//   Firebase Console → Firestore Database → Rules →
//   replace everything with this file → Publish
//
// ⚠ IMPORTANT: put YOUR Google email(s) in isKeeper() below.
//   Keep it in sync with adminEmails in js/config.js.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    // The keeper(s) of the realm — full moderation powers.
    function isKeeper() {
      return signedIn() && request.auth.token.email in [
        'benarp2144@gmail.com'
      ];
    }

    function validText(t, max) {
      return t is string && t.size() > 0 && t.size() <= max;
    }

    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // Optional coarse location — number pairs only, world bounds.
    function validLoc(d) {
      return !d.keys().hasAny(['loc'])
        || (d.loc.lat is number && d.loc.lng is number
            && d.loc.lat >= -90 && d.loc.lat <= 90
            && d.loc.lng >= -180 && d.loc.lng <= 180);
    }

    // ── prayers ────────────────────────────────────────────────────
    match /prayers/{prayerId} {

      // Anyone may read the altar — even before signing in.
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && validText(request.resource.data.text, 1200)
        && validText(request.resource.data.name, 80)
        && request.resource.data.anonymous is bool
        && request.resource.data.category in
           ['healing','family','faith','finances','protection','guidance','praise','other']
        && request.resource.data.prayedBy == []
        && request.resource.data.prayedCount == 0
        && request.resource.data.answered == false
        && request.resource.data.flags == []
        && request.resource.data.commentCount == 0
        && request.resource.data.reactions.keys().hasOnly(['love','dove','cross','fire'])
        && validLoc(request.resource.data);

      // The author or a keeper may remove a prayer.
      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isKeeper());

      // Updates are allowed ONLY as one of these precise moves:
      allow update: if signedIn() && (
        isAmen() || isReaction() || isAnsweredToggle() || isFlag() || isCommentCount()
      );

      // "I prayed" — append exactly your own uid, exactly once,
      // and keep the counter honest.
      function isAmen() {
        return changedOnly(['prayedBy', 'prayedCount'])
          && !(request.auth.uid in resource.data.prayedBy)
          && request.resource.data.prayedBy == resource.data.prayedBy.concat([request.auth.uid])
          && request.resource.data.prayedCount == request.resource.data.prayedBy.size();
      }

      // Reactions may change, but only the reactions map,
      // and only with the known reaction keys.
      function isReaction() {
        return changedOnly(['reactions'])
          && request.resource.data.reactions.keys().hasOnly(['love','dove','cross','fire']);
      }

      // Only the author may mark their prayer answered (or unmark).
      function isAnsweredToggle() {
        return changedOnly(['answered', 'answeredAt'])
          && resource.data.uid == request.auth.uid
          && request.resource.data.answered is bool;
      }

      // Reporting — append exactly your own uid to flags, once.
      function isFlag() {
        return changedOnly(['flags'])
          && !(request.auth.uid in resource.data.get('flags', []))
          && request.resource.data.flags == resource.data.get('flags', []).concat([request.auth.uid]);
      }

      // Comment counter bump (±1) after adding/removing a comment.
      function isCommentCount() {
        return changedOnly(['commentCount'])
          && request.resource.data.commentCount is int
          && request.resource.data.commentCount >= 0
          && (request.resource.data.commentCount - resource.data.get('commentCount', 0)) in [1, -1];
      }

      // ── words of encouragement (public comments) ─────────────────
      match /comments/{commentId} {
        allow read: if true;

        allow create: if signedIn()
          && request.resource.data.uid == request.auth.uid
          && validText(request.resource.data.text, 600)
          && validText(request.resource.data.name, 80)
          && request.resource.data.anonymous is bool;

        // Comment author, prayer author, or keeper may remove.
        allow delete: if signedIn() && (
          resource.data.uid == request.auth.uid
          || isKeeper()
          || get(/databases/$(database)/documents/prayers/$(prayerId)).data.uid == request.auth.uid
        );

        allow update: if false;
      }
    }

    // ── presence — one small doc per soul keeping watch ────────────
    match /presence/{uid} {
      allow read: if true;

      // Only you may write your own light; coarse coordinates or null.
      allow write: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && validText(request.resource.data.name, 80)
        && request.resource.data.keys().hasOnly(['uid','name','photo','lat','lng','lastSeen'])
        && (request.resource.data.lat == null
            || (request.resource.data.lat is number
                && request.resource.data.lat >= -90 && request.resource.data.lat <= 90))
        && (request.resource.data.lng == null
            || (request.resource.data.lng is number
                && request.resource.data.lng >= -180 && request.resource.data.lng <= 180));

      allow delete: if signedIn() && request.auth.uid == uid;
    }

    // ── words — private messages between exactly two saints ────────
    match /dms/{threadId} {

      function isParticipant() {
        return signedIn() && request.auth.uid in resource.data.users;
      }

      // Only the two participants can ever read a thread.
      // (Not even the keeper — private words stay private.)
      allow read: if isParticipant();

      // A thread is created by one of its two members, with a
      // deterministic id so the same pair always share one thread.
      allow create: if signedIn()
        && request.resource.data.users.size() == 2
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users[0] < request.resource.data.users[1]
        && threadId == request.resource.data.users[0] + '_' + request.resource.data.users[1];

      // Participants may only touch the preview/read-state fields.
      allow update: if isParticipant()
        && changedOnly(['lastText', 'lastFrom', 'updatedAt', 'readAt']);

      allow delete: if false;

      match /messages/{messageId} {
        function inThread() {
          return signedIn() && request.auth.uid in
            get(/databases/$(database)/documents/dms/$(threadId)).data.users;
        }

        allow read: if inThread();

        allow create: if inThread()
          && request.resource.data.from == request.auth.uid
          && validText(request.resource.data.text, 1000);

        // You may unsay your own words.
        allow delete: if signedIn() && resource.data.from == request.auth.uid;

        allow update: if false;
      }
    }

    // Everything else: sealed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
